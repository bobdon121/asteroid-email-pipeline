# Asteroid.ai Cold Email Pipeline - Environment Variables
# Copy this file to .env and fill in your actual values

# Anthropic API (Claude) - REQUIRED
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google APIs (for Google Sheets integration)
GOOGLE_API_KEY=your_google_api_key_here

# Sender Information - update before first run
SENDER_NAME=Yash Tyagi
SENDER_TITLE=GTM Lead, Asteroid.ai
SENDER_COMPANY=Asteroid.ai
COMPANY_ADDRESS=your_company_address_here

# Tracking & Compliance
UNSUBSCRIBE_URL=https://your-domain.com/unsubscribe

# Google Sheets (set after running setup_google_sheet.py)
GOOGLE_SHEET_ID=

# Email Sending via SMTP (optional - emails are manual by default)
SMTP1_SERVER=smtp.gmail.com
SMTP1_PORT=587
SMTP1_EMAIL=your-email@gmail.com
SMTP1_PASSWORD=app-specific-password

# IMAP for reply detection (optional)
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_EMAIL=your-email@gmail.com
IMAP_PASSWORD=your-app-specific-password
